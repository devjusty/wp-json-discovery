PORT=4100
FRONTEND_ORIGIN=http://localhost:5173
TURSO_DATABASE_URL=libsql://your-database-your-org.turso.io
TURSO_AUTH_TOKEN=your-token
# Optional: Turso control-plane token for stats/usage/instances in Admin Data health
TURSO_API_TOKEN=your-turso-api-token
# Optional overrides for API metric calls if db/org cannot be derived from the URL
TURSO_ORGANIZATION=your-org
TURSO_DATABASE_NAME=your-database
# Set to false to disable /api/admin/* endpoints outside of local dev
ADMIN_ENABLED=true
# Shared key required for /api/admin/* and /api/logs* (fallback for Auth0 admin tokens)
ADMIN_API_KEY=change-me
# Optional: archive cleanup policy applied on /api/logs/rotate
ACTIVITY_LOG_ARCHIVE_RETENTION_DAYS=21
ACTIVITY_LOG_ARCHIVE_MAX_FILES=30
# Auth0 configuration for authentication middleware
AUTH0_DOMAIN=your-tenant.auth0.com
# Optional: API audience for token validation. If omitted, any token from the Auth0 tenant is accepted.
# AUTH0_AUDIENCE=https://api.your-domain.com
