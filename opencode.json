{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false
    },
    "fallow": {
      "type": "local",
      "command": ["fallow-mcp"],
      "enabled": true
    },
    "hugeicons": {
      "type": "local",
      "command": ["npx", "-y", "@hugeicons/mcp-server"],
      "enabled": true
    },
    "netlify": {
      "type": "local",
      "command": ["npx", "-y", "@netlify/mcp"],
      "enabled": true
    },
    "render": {
      "type": "remote",
      "url": "https://mcp.render.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:RENDER_MCP_API_KEY}"
      }
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
    }
  }
}
